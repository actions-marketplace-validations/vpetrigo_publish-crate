{
  "name": "publish-crates",
  "version": "1.0.1",
  "private": true,
  "description": "GitHub Action to publish Rust crates using cargo-workspaces",
  "main": "dist/index.js",
  "keywords": [
    "cargo",
    "crate",
    "publish"
  ],
  "scripts": {
    "build": "bun build.mjs",
    "typecheck": "tsc --noEmit",
    "test": "BUN_TEST=1 bun test __tests__/index.test.ts",
    "test:integration": "BUN_TEST=1 bun test __tests__/integration/",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@actions/core": "^3.0.1",
    "@actions/exec": "^3.0.0",
    "@actions/io": "^3.0.2"
  },
  "devDependencies": {
    "@types/node": "^25.8.0",
    "esbuild": "^0.28.0",
    "esbuild-plugin-license": "^1.2.3",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  }
}
